# =============================================================================
# Variáveis de ambiente — copie para .env e preencha os valores
# NUNCA commite o arquivo .env real no GitHub
# =============================================================================

# ── Banco de dados (Railway provê automaticamente) ────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/railway"

# ── Telegram ───────────────────────────────────────────────────────────────────
# Obtenha em: t.me/BotFather → /newbot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff

# ── Efí Bank (Pix) ─────────────────────────────────────────────────────────────
# Painel Efí → API → Credenciais → Criar nova aplicação
EFI_CLIENT_ID=Client_Id_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EFI_CLIENT_SECRET=Client_Secret_xxxxxxxxxxxxxxxxxxxxxxxx
# Sua chave Pix cadastrada na conta Efí (CPF, CNPJ, email, telefone ou aleatória)
EFI_PIX_KEY=sua@chave.pix
# Certificado mTLS em base64 — baixe .p12 no painel Efí e converta:
#   base64 -i certificado.p12 | tr -d '\n'
EFI_CERTIFICATE_BASE64=
# true = sandbox (testes), false = produção
EFI_SANDBOX=false
# Opcional — webhook secret configurado no painel Efí
# EFI_WEBHOOK_SECRET=

# ── Stripe (Assinaturas) ────────────────────────────────────────────────────────
# Painel Stripe → Developers → API Keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Painel Stripe → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Admin Panel ─────────────────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=sua-chave-de-32-chars-minimo-aqui

# ── App ──────────────────────────────────────────────────────────────────────────
# URL pública do backend (usada pelo Stripe para success/cancel URLs)
APP_BASE_URL=https://seu-backend.railway.app

# Porta (Railway define automaticamente via variável PORT)
PORT=3000
