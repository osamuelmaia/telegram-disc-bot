generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum BotStatus {
  INACTIVE
  ACTIVE
  ERROR
}

enum ProductType {
  ONE_TIME
  RECURRING
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum PaymentGateway {
  EFI
  STRIPE
  MERCADO_PAGO
}

enum OrderStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SubscriptionStatus {
  PENDING
  TRIALING
  ACTIVE
  PAST_DUE
  UNPAID
  CANCELLED
  EXPIRED
}

enum AccessStatus {
  ACTIVE
  REVOKED
}

enum WebhookStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
  FAILED
}

enum WalletTransactionType {
  CREDIT_SALE
  DEBIT_PLATFORM_FEE
  DEBIT_WITHDRAWAL
  CREDIT_REFUND
}

// =============================================================================
// PLATFORM CONFIG — singleton
// =============================================================================

model PlatformConfig {
  id                  String  @id @default(cuid())
  defaultFeePercent   Decimal @default(0.0500) @db.Decimal(5, 4)
  minWithdrawalAmount Decimal @default(50.00)  @db.Decimal(10, 2)
  notificationEmail   String?
  updatedAt           DateTime @updatedAt

  @@map("platform_config")
}

// =============================================================================
// TENANT
// =============================================================================

model Tenant {
  id       String       @id @default(cuid())
  name     String
  email    String       @unique
  password String
  status   TenantStatus @default(PENDING)

  pixKeyType  String?
  pixKeyValue String?

  personType       String?
  document         String?
  birthDate        String?
  zipCode          String?
  address          String?
  profileCompleted Boolean  @default(false)

  platformFeePercent Decimal? @db.Decimal(5, 4)

  bot                   Bot?
  products              Product[]
  orders                Order[]
  subscriptions         Subscription[]
  accesses              Access[]
  webhookEvents         WebhookEvent[]
  paymentGatewayConfigs PaymentGatewayConfig[]
  wallet                Wallet?
  endUsers              EndUser[]
  withdrawalRequests    WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
  @@map("tenants")
}

// =============================================================================
// BOT
// =============================================================================

model Bot {
  id             String    @id @default(cuid())
  tenantId       String    @unique
  token          String    @unique
  username       String?
  status         BotStatus @default(INACTIVE)
  welcomeMessage String?
  supportContact String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bots")
}

// =============================================================================
// END USER
// =============================================================================

model EndUser {
  id         String  @id @default(cuid())
  tenantId   String
  telegramId BigInt
  username   String?
  firstName  String?
  lastName   String?

  orders        Order[]
  subscriptions Subscription[]
  accesses      Access[]

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, telegramId])
  @@index([telegramId])
  @@index([tenantId])
  @@map("end_users")
}

// =============================================================================
// PAYMENT GATEWAY CONFIG
// =============================================================================

model PaymentGatewayConfig {
  id          String         @id @default(cuid())
  tenantId    String
  gateway     PaymentGateway
  active      Boolean        @default(false)
  credentials String         // JSON criptografado com AES-256-GCM

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, gateway])
  @@index([tenantId])
  @@map("payment_gateway_configs")
}

// =============================================================================
// PRODUCT
// =============================================================================

model Product {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  type            ProductType
  price           Decimal          @db.Decimal(10, 2)
  currency        String           @default("BRL")
  billingInterval BillingInterval?
  trialDays       Int?
  chatId          String?
  active          Boolean          @default(true)

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  orders        Order[]
  subscriptions Subscription[]
  accesses      Access[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@map("products")
}

// =============================================================================
// ORDER
// =============================================================================

model Order {
  id        String @id @default(cuid())
  tenantId  String
  endUserId String
  productId String

  status  OrderStatus    @default(PENDING)
  gateway PaymentGateway

  gatewayOrderId  String?
  gatewayTxid     String?
  pixEndToEndId   String?

  amount            Decimal @default(0) @db.Decimal(10, 2)
  platformFeeAmount Decimal @default(0) @db.Decimal(10, 2)
  netAmount         Decimal @default(0) @db.Decimal(10, 2)
  currency          String  @default("BRL")

  pixCopyPaste    String?
  pixQrCodeBase64 String?
  pixQrCodeUrl    String?

  expiresAt       DateTime?
  paidAt          DateTime?
  gatewayResponse Json?

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  endUser  EndUser @relation(fields: [endUserId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  access   Access?

  walletTransactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([gatewayTxid])
  @@map("orders")
}

// =============================================================================
// SUBSCRIPTION
// =============================================================================

model Subscription {
  id        String @id @default(cuid())
  tenantId  String
  endUserId String
  productId String

  status  SubscriptionStatus @default(PENDING)
  gateway PaymentGateway

  gatewaySubscriptionId String?
  checkoutUrl           String?

  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  cancelledAt       DateTime?

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  endUser  EndUser @relation(fields: [endUserId], references: [id])
  product  Product @relation(fields: [productId], references: [id])
  access   Access?

  payments SubscriptionPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([gatewaySubscriptionId])
  @@map("subscriptions")
}

// =============================================================================
// SUBSCRIPTION PAYMENT
// =============================================================================

model SubscriptionPayment {
  id             String @id @default(cuid())
  subscriptionId String

  gatewayInvoiceId String?
  amount           Decimal       @db.Decimal(10, 2)
  platformFeeAmount Decimal      @default(0) @db.Decimal(10, 2)
  netAmount        Decimal       @default(0) @db.Decimal(10, 2)
  currency         String        @default("BRL")
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?

  walletTransactions WalletTransaction[]
  subscription       Subscription @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subscriptionId])
  @@map("subscription_payments")
}

// =============================================================================
// ACCESS
// =============================================================================

model Access {
  id        String @id @default(cuid())
  tenantId  String
  endUserId String
  productId String
  chatId    String

  status AccessStatus @default(ACTIVE)

  inviteLink     String?
  orderId        String? @unique
  subscriptionId String? @unique

  grantedAt     DateTime  @default(now())
  revokedAt     DateTime?
  revokedReason String?
  expiresAt     DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  endUser      EndUser       @relation(fields: [endUserId], references: [id])
  product      Product       @relation(fields: [productId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, endUserId, status])
  @@map("accesses")
}

// =============================================================================
// WALLET
// =============================================================================

model Wallet {
  id             String  @id @default(cuid())
  tenantId       String  @unique
  balance        Decimal @default(0) @db.Decimal(14, 2)
  totalReceived  Decimal @default(0) @db.Decimal(14, 2)
  totalFees      Decimal @default(0) @db.Decimal(14, 2)
  totalWithdrawn Decimal @default(0) @db.Decimal(14, 2)

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  transactions WalletTransaction[]
  withdrawals  WithdrawalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("wallets")
}

// =============================================================================
// WALLET TRANSACTION — append-only ledger
// =============================================================================

model WalletTransaction {
  id            String                @id @default(cuid())
  walletId      String
  type          WalletTransactionType
  amount        Decimal               @db.Decimal(14, 2)
  balanceBefore Decimal               @db.Decimal(14, 2)
  balanceAfter  Decimal               @db.Decimal(14, 2)
  description   String?

  orderId               String?
  subscriptionPaymentId String?
  withdrawalRequestId   String?

  order               Order?               @relation(fields: [orderId], references: [id])
  subscriptionPayment SubscriptionPayment? @relation(fields: [subscriptionPaymentId], references: [id])
  withdrawalRequest   WithdrawalRequest?   @relation(fields: [withdrawalRequestId], references: [id])
  wallet              Wallet               @relation(fields: [walletId], references: [id])

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([walletId, type])
  @@index([orderId])
  @@map("wallet_transactions")
}

// =============================================================================
// WITHDRAWAL REQUEST
// =============================================================================

model WithdrawalRequest {
  id       String @id @default(cuid())
  walletId String
  tenantId String

  amount          Decimal          @db.Decimal(14, 2)
  status          WithdrawalStatus @default(PENDING)
  pixKeyType      String
  pixKeyValue     String

  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  completedAt     DateTime?
  pixTransactionId String?
  failureReason   String?

  wallet       Wallet              @relation(fields: [walletId], references: [id])
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  transactions WalletTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([status])
  @@map("withdrawal_requests")
}

// =============================================================================
// WEBHOOK EVENT
// =============================================================================

model WebhookEvent {
  id        String         @id @default(cuid())
  tenantId  String
  gateway   PaymentGateway
  eventId   String
  eventType String
  status    WebhookStatus  @default(RECEIVED)
  payload   Json
  processedAt DateTime?
  error     String?
  attempts  Int            @default(0)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, gateway, eventId])
  @@index([tenantId])
  @@index([status])
  @@map("webhook_events")
}
